# === Backend ===
PORT=3000
ENVIRONMENT=development
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=xxxxx

# Database (Supabase PostgreSQL oder lokal)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resellos

# Redis (fuer Celery + Cache)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Retention (DSGVO)
RETENTION_DATA_DAYS=365
RETENTION_LOGS_DAYS=30

# Perplexity API (gleicher Key fuer Search API + Sonar API)
PERPLEXITY_API_KEY=pplx-xxxxx

# Search API Tuning
PERPLEXITY_SEARCH_COUNTRY=DE
PERPLEXITY_SEARCH_RECENCY=month
PERPLEXITY_SEARCH_MAX_RESULTS=10

# Sonar API Tuning (Listing-Text-Generierung)
PERPLEXITY_SONAR_MODEL=sonar
PERPLEXITY_SONAR_SEARCH_CONTEXT_SIZE=low

# ResellOS
DEAD_STOCK_THRESHOLD_DAYS=30
DEFAULT_PLATFORM_TONALITY=vinted

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# === Frontend ===
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_BASE_URL=http://localhost:3000/api/v1
