    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.1.0",
    "nativewind": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "zustand": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "react-native-mmkv": "^3.0.0",
    "react-hook-form": "^7.50.0",
